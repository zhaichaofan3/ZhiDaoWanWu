## 前端（Vite）
VITE_API_BASE_URL=http://localhost:4000

## 后端（Express）
PORT=4000

## 必填：用于生成/校验登录 token
## 建议执行：npm run gen:secrets 生成随机值（不要把真实值提交到仓库）
TOKEN_SECRET=change-me-token-secret

## 可选：仅用于兼容旧版 md5 密码（当数据库里仍存在 md5: 前缀密码哈希时需要）
PASSWORD_SALT=change-me-password-salt

## bcrypt 计算强度（建议 10-12；范围限制 8-15）
BCRYPT_ROUNDS=10

## AI（科大讯飞星火）- WebSocket（可选，不配也能跑，相关功能会不可用/降级）
XF_WS_URL=wss://spark-api.xf-yun.com/v3.1/chat
XF_DOMAIN=generalv3
XF_APP_ID=
XF_API_KEY=
XF_API_SECRET=

## MySQL（后端仅使用分段配置，不需要 MYSQL_URL）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=second_hand_db
MYSQL_CONNECTION_LIMIT=10

## 短信（push.spug.cc）- 必填（当前后端启动时会校验）
## 注意：短信模板编号在某种程度上等同于 API Key，请勿提交真实值到仓库
SPUG_SMS_TEMPLATE_ID=
SPUG_SMS_SIGN_NAME=拾物社

## OSS（S3-compatible）- 可选（未配置时会回退到本地 uploads/）
OSS_PROVIDER=s3-compatible
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_BUCKET=
OSS_REGION=us-east-1
## S3 端点（服务端访问；若为空会使用 OSS_EXTERNAL_ENDPOINT）
OSS_ENDPOINT=
## 可选：外网端点（当 OSS_ENDPOINT 为空时使用；也可用于对外拼接访问链接）
OSS_EXTERNAL_ENDPOINT=
## 可选：内网端点（当前代码未强依赖；保留用于部署场景）
OSS_INTERNAL_ENDPOINT=
## 用于拼接对外访问链接（可留空，默认同 OSS_EXTERNAL_ENDPOINT）
OSS_PUBLIC_BASE_URL=
## S3 兼容存储通常需要 true（MinIO/COS/Ceph 常见）
OSS_FORCE_PATH_STYLE=true
## 预签名上传 URL 有效期（秒）
OSS_UPLOAD_EXPIRES=600

## 邮件服务配置
# SMTP 服务器地址
EMAIL_SMTP_HOST=smtp.example.com
# SMTP 服务器端口
EMAIL_SMTP_PORT=587
# SMTP 用户名
EMAIL_SMTP_USER=your-email@example.com
# SMTP 密码
EMAIL_SMTP_PASS=your-email-password
# 发件人邮箱
EMAIL_FROM=your-email@example.com
# 发件人名称
EMAIL_FROM_NAME=拾物社