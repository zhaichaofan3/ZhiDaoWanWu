VITE_API_BASE_URL=http://localhost:4000

PORT=4000
TOKEN_SECRET=change-me-token-secret
PASSWORD_SALT=change-me-password-salt

XF_APP_ID=
XF_API_KEY=
XF_API_SECRET=

MYSQL_URL=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=second_hand
MYSQL_CONNECTION_LIMIT=10
SQLITE_PATH=./server/data.sqlite

# OSS (S3-compatible) - MinIO/阿里云OSS S3兼容/COS S3兼容/Ceph
OSS_PROVIDER=s3-compatible
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_BUCKET=
OSS_REGION=us-east-1
# 服务端访问端点（建议使用可从本机直连的外网地址）
OSS_ENDPOINT=
# 可选：单独配置外网端点（当 OSS_ENDPOINT 为空时使用）
OSS_EXTERNAL_ENDPOINT=
# 用于拼接对外访问链接（可留空）
OSS_PUBLIC_BASE_URL=
# S3 兼容存储通常需要 true
OSS_FORCE_PATH_STYLE=true
# 预签名上传 URL 有效期（秒）
OSS_UPLOAD_EXPIRES=600
